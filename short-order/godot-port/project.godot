; Short Order — Godot project
; Open this folder with Godot 4.4+ (tested target: 4.x line).

config_version=5

[application]

config/name="Short Order"
config/description="After hours. The patrons came back."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")

[autoload]

Controls="*res://scripts/controls.gd"
Weapons="*res://scripts/weapons.gd"
Juice="*res://scripts/juice.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
; 0 = Landscape (handhelds / phones)
window/handheld/orientation=0

[rendering]

renderer/rendering_method="forward_plus"
renderer/rendering_method.mobile="mobile"
anti_aliasing/quality/msaa_3d=1
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=2

[physics]

3d/default_gravity=24.0
